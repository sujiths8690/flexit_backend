generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Business {
  id                Int              @id @default(autoincrement())
  name              String
  mobile            String?
  email             String?
  isActive          Boolean          @default(true)
  address           String?           @db.VarChar(100)

  users             User[]
  categories        Category[]
  products          Product[]
  combos            ComboOffer[]
  settings          Setting[]
  blackList         BlackList[]
  userActivity      UserActivity[]

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @default(now())
}

model BlackList{
    id              Int             @id @default(autoincrement())
    businessId      Int
    fromDate        DateTime
    lastDate        DateTime

    business        Business        @relation(fields:[businessId], references: [id])

    updatedAt       DateTime        @default(now())
}

model User {
  id                Int             @id @default(autoincrement())
  username          String          @unique
  passwordHash      String          @db.VarChar(255)
  role              Role            @default(ADMIN)
  mobileNumber      String?         @db.VarChar(12)
  email             String?         @unique
  isActive          Boolean         @default(true)
  lastLogin         DateTime?

  businessId        Int
  business          Business        @relation(fields: [businessId], references: [id])

  PasswordResetToken  PasswordResetToken[]
  UserActivity      UserActivity[]

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model PasswordResetToken {
  id                Int             @id @default(autoincrement())
  tokenHash         String          @db.VarChar(50)
  expiresAt         DateTime

  userId            Int
  user              User            @relation(fields: [userId], references: [id])

  createdAt         DateTime        @default(now())
}


model UserActivity{
  id                Int             @id @default(autoincrement())

  businessId        Int
  business          Business        @relation(fields: [businessId], references: [id])

  userId            Int
  user              User            @relation(fields: [userId], references: [id])

  userActivityType  String          @db.VarChar(50)
  UserActivityDesc  String          @db.VarChar(50)
  flagActivity      Boolean         @default(false)

  date              DateTime        @default(now())

}

model Setting {
  id                Int             @id @default(autoincrement())
  keyName           String          @db.VarChar(20)
  value             String?         @db.VarChar(20)

  businessId        Int
  business          Business        @relation(fields: [businessId], references: [id])

  @@unique([businessId, keyName])
}

model Category {
  id                Int             @id @default(autoincrement())
  name              String          @db.VarChar(30)
  position          Int             @default(0)

  businessId        Int
  business          Business        @relation(fields: [businessId], references: [id])

  products          Product[]
}

model Product {
  id                Int             @id @default(autoincrement())
  name              String          @db.VarChar(50)
  description       String?         @db.VarChar(200)
  price             Decimal         @default(0.00)
  vegFlag           VegType?         @default(veg)
  imageUrl          String?
  isAvailable       Boolean         @default(true)
  position          Int             @default(0)

  categoryId        Int?
  category          Category?       @relation(fields: [categoryId], references: [id])

  businessId        Int
  business          Business        @relation(fields: [businessId], references: [id])

  comboItems        ComboOfferItem[]
  todaysStar        TodaysStar?
  todaysOffer       TodaysOffer?

  isActive          Boolean         @default(true)
}

model ComboOffer {
  id                Int             @id @default(autoincrement())
  name              String          @db.VarChar(50)
  description       String?         @db.VarChar(200)
  price             Decimal?
  imageUrl          String?
  isActive          Boolean         @default(true)

  businessId        Int
  business          Business        @relation(fields: [businessId], references: [id])

  items             ComboOfferItem[]
}

model ComboOfferItem {
  id                Int             @id @default(autoincrement())
  quantity          Int             @default(1)

  comboId           Int
  combo             ComboOffer      @relation(fields: [comboId], references: [id])

  productId         Int
  product           Product         @relation(fields: [productId], references: [id])
}

model TodaysStar {
  id                Int             @id @default(autoincrement())

  productId         Int             @unique
  product           Product         @relation(fields: [productId], references: [id])
}

model TodaysOffer {
  id                Int             @id @default(autoincrement())
  offerPrice        Decimal

  productId         Int             @unique
  product           Product         @relation(fields: [productId], references: [id])
}

enum VegType {
  veg
  non_veg
}

enum Role {
  ADMIN
  STAFF
  VIEWER
}