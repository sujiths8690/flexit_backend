generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Business {
  id                Int              @id @default(autoincrement())
  name              String
  mobile            String?
  email             String?
  logoUrl           String?
  showPrice         Boolean          @default(true)
  showDescription   Boolean          @default(true)
  showLogo          Boolean          @default(true)
  showCompanyName   Boolean          @default(true)
  showProductImage  Boolean          @default(true)
  showDietTags      Boolean          @default(true)
  isActive          Boolean          @default(true)
  address           String?           @db.VarChar(100)

  categories        Category[]
  products          Product[]
  combos            ComboOffer[]
  todaysStars       TodaysStar[]
  settings          Setting[]
  blackList         BlackList[]
  devices           Device[]
  media             Media[]

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model Device {
  id            Int       @id @default(autoincrement())
  deviceCode    String    @unique
  name          String?

  displayMode   DisplayMode @default(FULL_MENU)
  orientation   String      @default("normal")
  menuTheme     String      @default("light")
  themeColor    String      @default("gold")
  displayContentMode String  @default("allCategories")
  selectedCategoryId Int?
  selectedMediaId Int?
  transitionStyle String     @default("fade")
  transitionSpeedSeconds Float @default(0.5)
  autoScrollIntervalSeconds Int @default(8)
  scheduleEnabled Boolean @default(false)
  alwaysOn Boolean @default(true)
  scheduleStartTime String @default("09:00")
  scheduleEndTime String @default("22:00")
  showPrice         Boolean   @default(true)
  showDescription   Boolean   @default(true)
  showLogo          Boolean   @default(true)
  showCompanyName   Boolean   @default(true)
  showProductImage  Boolean   @default(true)
  showDietTags      Boolean   @default(true)
  headingFontScale  Float     @default(1.0)
  nameFontScale     Float     @default(1.0)
  descriptionFontScale Float  @default(1.0)
  priceFontScale    Float     @default(1.0)

  businessId    Int
  business      Business  @relation(fields: [businessId], references: [id])

  deviceMedia   DeviceMedia[]

  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
}

model Media {
  id          Int      @id @default(autoincrement())
  fileName    String
  url         String

  type        MediaType
  duration    Int?

  version     Int      @default(1) 

  businessId  Int
  business    Business @relation(fields: [businessId], references: [id])

  deviceMedia DeviceMedia[]

  createdAt   DateTime @default(now())
}

model DeviceMedia {
  id        Int     @id @default(autoincrement())

  deviceId  Int
  device    Device  @relation(fields: [deviceId], references: [id])

  mediaId   Int
  media     Media   @relation(fields: [mediaId], references: [id])

  position  Int     @default(0)

  @@unique([deviceId, mediaId])
}

model BlackList{
    id              Int             @id @default(autoincrement())
    businessId      Int
    fromDate        DateTime
    lastDate        DateTime

    business        Business        @relation(fields:[businessId], references: [id])

    updatedAt       DateTime        @default(now())
}

model Setting {
  id                Int             @id @default(autoincrement())
  keyName           String          @db.VarChar(20)
  value             String?         @db.VarChar(20)

  businessId        Int
  business          Business        @relation(fields: [businessId], references: [id])

  @@unique([businessId, keyName])
}

model Category {
  id                Int             @id @default(autoincrement())
  name              String          @db.VarChar(30)
  position          Int             @default(0)

  businessId        Int
  business          Business        @relation(fields: [businessId], references: [id])

  products          Product[]
}

model Product {
  id                Int             @id @default(autoincrement())
  name              String          @db.VarChar(50)
  description       String?         @db.VarChar(200)
  price             Decimal         @default(0.00)
  priceVariants     Json?
  vegFlag           VegType?         @default(veg)
  imageUrl          String?
  isAvailable       Boolean         @default(true)
  position          Int             @default(0)

  categoryId        Int?
  category          Category?       @relation(fields: [categoryId], references: [id])

  businessId        Int
  business          Business        @relation(fields: [businessId], references: [id])

  comboItems        ComboOfferItem[]
  todaysStar        TodaysStar[]
  todaysOffer       TodaysOffer?

  isActive          Boolean         @default(true)
}

model ComboOffer {
  id                Int             @id @default(autoincrement())
  name              String          @db.VarChar(50)
  description       String?         @db.VarChar(200)
  price             Decimal?
  imageUrl          String?
  startDate         DateTime?
  endDate           DateTime?
  isActive          Boolean         @default(true)

  businessId        Int
  business          Business        @relation(fields: [businessId], references: [id])

  items             ComboOfferItem[]
}

model ComboOfferItem {
  id                Int             @id @default(autoincrement())
  quantity          Int             @default(1)
  variantLabel      String?         @db.VarChar(50)
  variantPrice      Decimal?

  comboId           Int
  combo             ComboOffer      @relation(fields: [comboId], references: [id])

  productId         Int
  product           Product         @relation(fields: [productId], references: [id])
}

model TodaysStar {
  id                Int             @id @default(autoincrement())
  starDate          DateTime
  createdAt         DateTime        @default(now())

  businessId        Int
  business          Business        @relation(fields: [businessId], references: [id])

  productId         Int
  product           Product         @relation(fields: [productId], references: [id])

  @@unique([businessId, starDate, productId])
}

model TodaysOffer {
  id                Int             @id @default(autoincrement())
  offerPrice        Decimal

  productId         Int             @unique
  product           Product         @relation(fields: [productId], references: [id])
}

enum VegType {
  veg
  non_veg
}

enum DisplayMode {
  FULL_MENU
  TODAY_STAR
  TODAY_OFFER
  COMBO
}

enum MediaType {
  IMAGE
  VIDEO
}
