generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Business {
  id                Int              @id @default(autoincrement())
  name              String
  mobile            String?
  email             String?
  logoUrl           String?
  showPrice         Boolean          @default(true)
  showDescription   Boolean          @default(true)
  showLogo          Boolean          @default(true)
  showCompanyName   Boolean          @default(true)
  showProductImage  Boolean          @default(true)
  showDietTags      Boolean          @default(true)
  showComboItemQuantity Boolean       @default(true)
  isActive          Boolean          @default(true)
  address           String?           @db.VarChar(100)
  subscriptionPlanId String?
  subscriptionPlanName String?
  subscriptionStatus String?
  subscriptionAmount Decimal?         @default(0.00)
  subscriptionCurrency String?        @default("INR")
  subscriptionStartedAt DateTime?
  subscriptionTrialEndsAt DateTime?
  subscriptionOfferPlanId String?
  subscriptionOfferPlanName String?
  subscriptionOfferOriginalAmount Decimal?
  subscriptionOfferAmount Decimal?
  subscriptionOfferCurrency String?   @default("INR")
  subscriptionOfferExpiresAt DateTime?
  subscriptionOfferCreatedAt DateTime?
  subscriptionExtensionDays Int?
  subscriptionExtensionPreviousEndsAt DateTime?
  subscriptionExtensionNewEndsAt DateTime?
  subscriptionExtensionCreatedAt DateTime?

  categories        Category[]
  products          Product[]
  combos            ComboOffer[]
  offers            Offer[]
  todaysStars       TodaysStar[]
  notices           Notice[]
  settings          Setting[]
  blackList         BlackList[]
  devices           Device[]
  media             Media[]
  planTransactions  PlanTransaction[]
  adminOffers       BusinessAdminOffer[]
  mobileNotifications MobileNotification[]
  mobilePushTokens  MobilePushToken[]

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model MobileNotification {
  id          Int       @id @default(autoincrement())
  target      String    @default("BUSINESS")
  title       String    @db.VarChar(120)
  message     String    @db.Text
  category    String    @default("GENERAL")
  meta        Json?
  sentAt      DateTime  @default(now())
  deletedAt   DateTime?

  businessId  Int?
  business    Business? @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([target])
  @@index([sentAt])
  @@index([deletedAt])
}

model MobilePushToken {
  id          Int      @id @default(autoincrement())
  token       String   @unique @db.VarChar(512)
  platform    String   @default("android")
  app         String   @default("tex_flutter_app")
  isActive    Boolean  @default(true)
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  businessId  Int
  business    Business @relation(fields: [businessId], references: [id])
  userId      Int?

  @@index([businessId])
  @@index([userId])
  @@index([isActive])
  @@index([app])
}

model BusinessAdminOffer {
  id             Int      @id @default(autoincrement())
  type           String
  planId         String?
  planName       String?
  originalAmount Decimal?
  offerAmount    Decimal?
  currency       String   @default("INR")
  extensionDays  Int?
  previousEndsAt DateTime?
  newEndsAt      DateTime?
  validUntil     DateTime?
  createdAt      DateTime @default(now())

  businessId     Int
  business       Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([type])
  @@index([validUntil])
}

model SubscriptionPlanConfig {
  id             String   @id
  name           String
  summary        String   @db.Text
  minTvDevices   Int
  maxTvDevices   Int
  amount         Decimal  @default(0.00)
  currency       String   @default("INR")
  trialDays      Int?
  features       Json?
  discountName   String?
  discountAmount Decimal?
  discountEndsAt DateTime?
  updatedAt      DateTime @updatedAt
}

model PlanTransaction {
  id                Int       @id @default(autoincrement())
  transactionId     String    @unique
  invoiceId         String    @unique
  amount            Decimal   @default(0.00)
  currency          String    @default("INR")
  status            String    @default("success")
  method            String    @default("plan")
  planId            String?
  planName          String?
  description       String?   @db.Text
  customerId        Int?
  customerName      String?
  customerEmail     String?
  customerPhone     String?
  rawDetails        Json?

  businessId        Int
  business          Business  @relation(fields: [businessId], references: [id])

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([businessId])
  @@index([status])
  @@index([createdAt])
}

model Device {
  id            Int       @id @default(autoincrement())
  deviceCode    String    @unique
  name          String?
  manufacturer  String?
  brand         String?
  model         String?
  product       String?
  deviceName    String?
  board         String?
  hardware      String?
  androidVersion String?
  sdkInt        Int?
  buildId       String?
  buildDisplay  String?
  fingerprint   String?   @db.Text
  serialNumber  String?
  androidId     String?
  macAddress    String?
  ipAddress     String?
  screenWidth   Int?
  screenHeight  Int?
  screenPixelRatio Float?
  platform      String?
  osVersion     String?   @db.Text
  appVersion    String?
  rawDeviceInfo Json?

  displayMode   DisplayMode @default(FULL_MENU)
  orientation   String      @default("normal")
  menuTheme     String      @default("light")
  themeColor    String      @default("gold")
  displayLanguage String    @default("english")
  displayContentMode String  @default("allCategories")
  selectedCategoryId Int?
  selectedMediaId Int?
  transitionStyle String     @default("fade")
  transitionSpeedSeconds Float @default(0.5)
  autoScrollIntervalSeconds Int @default(8)
  scheduleEnabled Boolean @default(false)
  alwaysOn Boolean @default(true)
  scheduleStartTime String @default("09:00")
  scheduleEndTime String @default("22:00")
  showPrice         Boolean   @default(true)
  showDescription   Boolean   @default(true)
  showLogo          Boolean   @default(true)
  showCompanyName   Boolean   @default(true)
  showProductImage  Boolean   @default(true)
  showDietTags      Boolean   @default(true)
  showComboItemQuantity Boolean @default(true)
  headingFontScale  Float     @default(1.0)
  nameFontScale     Float     @default(1.0)
  descriptionFontScale Float  @default(1.0)
  priceFontScale    Float     @default(1.0)

  businessId    Int
  business      Business  @relation(fields: [businessId], references: [id])

  deviceMedia   DeviceMedia[]

  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
}

model Media {
  id          Int      @id @default(autoincrement())
  fileName    String
  url         String

  type        MediaType
  duration    Int?

  version     Int      @default(1) 

  businessId  Int
  business    Business @relation(fields: [businessId], references: [id])

  deviceMedia DeviceMedia[]

  createdAt   DateTime @default(now())
}

model DeviceMedia {
  id        Int     @id @default(autoincrement())

  deviceId  Int
  device    Device  @relation(fields: [deviceId], references: [id])

  mediaId   Int
  media     Media   @relation(fields: [mediaId], references: [id])

  position  Int     @default(0)

  @@unique([deviceId, mediaId])
}

model BlackList{
    id              Int             @id @default(autoincrement())
    businessId      Int
    fromDate        DateTime
    lastDate        DateTime

    business        Business        @relation(fields:[businessId], references: [id])

    updatedAt       DateTime        @default(now())
}

model Setting {
  id                Int             @id @default(autoincrement())
  keyName           String          @db.VarChar(20)
  value             String?         @db.VarChar(20)

  businessId        Int
  business          Business        @relation(fields: [businessId], references: [id])

  @@unique([businessId, keyName])
}

model Category {
  id                Int             @id @default(autoincrement())
  name              String          @db.VarChar(30)
  position          Int             @default(0)

  businessId        Int
  business          Business        @relation(fields: [businessId], references: [id])

  products          Product[]
}

model Product {
  id                Int             @id @default(autoincrement())
  name              String          @db.VarChar(50)
  description       String?         @db.VarChar(200)
  price             Decimal         @default(0.00)
  priceVariants     Json?
  vegFlag           VegType?         @default(veg)
  imageUrl          String?
  isAvailable       Boolean         @default(true)
  position          Int             @default(0)

  categoryId        Int?
  category          Category?       @relation(fields: [categoryId], references: [id])

  businessId        Int
  business          Business        @relation(fields: [businessId], references: [id])

  comboItems        ComboOfferItem[]
  offerItems        OfferItem[]
  freeInOffers      Offer[]          @relation("OfferFreeProduct")
  freeInOfferItems  OfferItem[]      @relation("OfferItemFreeProduct")
  todaysStar        TodaysStar[]
  todaysOffer       TodaysOffer?

  isActive          Boolean         @default(true)
}

model ComboOffer {
  id                Int             @id @default(autoincrement())
  name              String          @db.VarChar(50)
  description       String?         @db.VarChar(200)
  price             Decimal?
  imageUrl          String?
  startDate         DateTime?
  endDate           DateTime?
  isActive          Boolean         @default(true)

  businessId        Int
  business          Business        @relation(fields: [businessId], references: [id])

  items             ComboOfferItem[]
}

model ComboOfferItem {
  id                Int             @id @default(autoincrement())
  quantity          Int             @default(1)
  variantLabel      String?         @db.VarChar(50)
  variantPrice      Decimal?

  comboId           Int
  combo             ComboOffer      @relation(fields: [comboId], references: [id])

  productId         Int
  product           Product         @relation(fields: [productId], references: [id])
}

model Offer {
  id                Int             @id @default(autoincrement())
  name              String          @db.VarChar(50)
  offerType         String          @db.VarChar(20)
  discountPrice     Decimal?
  buyQuantity       Int?
  freeQuantity      Int?
  startDate         DateTime?
  endDate           DateTime?
  isActive          Boolean         @default(true)

  businessId        Int
  business          Business        @relation(fields: [businessId], references: [id])

  freeProductId     Int?
  freeProduct       Product?        @relation("OfferFreeProduct", fields: [freeProductId], references: [id])

  items             OfferItem[]
}

model OfferItem {
  id                Int             @id @default(autoincrement())
  quantity          Int             @default(1)
  variantLabel      String?         @db.VarChar(50)
  variantPrice      Decimal?
  discountPrice     Decimal?
  buyQuantity       Int?
  freeQuantity      Int?
  freeVariantLabel  String?         @db.VarChar(50)
  freeVariantPrice  Decimal?

  offerId           Int
  offer             Offer           @relation(fields: [offerId], references: [id])

  productId         Int
  product           Product         @relation(fields: [productId], references: [id])

  freeProductId     Int?
  freeProduct       Product?        @relation("OfferItemFreeProduct", fields: [freeProductId], references: [id])
}

model TodaysStar {
  id                Int             @id @default(autoincrement())
  starDate          DateTime
  createdAt         DateTime        @default(now())

  businessId        Int
  business          Business        @relation(fields: [businessId], references: [id])

  productId         Int
  product           Product         @relation(fields: [productId], references: [id])

  @@unique([businessId, starDate, productId])
}

model Notice {
  id                Int             @id @default(autoincrement())
  content           String          @db.Text
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  businessId        Int
  business          Business        @relation(fields: [businessId], references: [id])
}

model TodaysOffer {
  id                Int             @id @default(autoincrement())
  offerPrice        Decimal

  productId         Int             @unique
  product           Product         @relation(fields: [productId], references: [id])
}

enum VegType {
  veg
  non_veg
}

enum DisplayMode {
  FULL_MENU
  TODAY_STAR
  TODAY_OFFER
  COMBO
}

enum MediaType {
  IMAGE
  VIDEO
}
