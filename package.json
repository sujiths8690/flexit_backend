{
  "name": "texboard",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "serve": "concurrently \"npm run server:start\" \"npm run client:serve\"",
    "build": "concurrently \"npm run server:build\" \"npm run client:build\"",
    "server": "cd server && npm run dev",
    "server:build": "cd server && npm run build",
    "server:start": "cd server && npm run start",
    "server:prisma:merge": "cd server && npm run prisma:merge",
    "server:prisma:migrate": "cd server && npm run prisma:migrate",
    "server:prisma:generate": "cd server && npm run prisma:generate",
    "client": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "client:serve": "cd client && serve -s dist -l tcp://0.0.0.0:5002",
    "client:preview": "cd client && npm run preview",
    "client:lint": "cd client && npm run lint",
    "client:fix": "cd client && npm run fix"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.5",
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "nodemailer": "^7.0.12",
    "package.json": "^2.0.1"
  }
}
